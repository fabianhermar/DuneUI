---
import Grid from './Grid.astro'
import Link from './Link.astro'
---

<section class='text-gray-600 overflow-hidden wave px-2'>
	<div class='container px-5 py-32 mx-auto'>
		<div class='flex flex-col text-center w-full mb-20 gap-4'>
			<span
				class='text-transparent bg-clip-text bg-linear-to-r from-[#93603e] via-[#c18156] to-[#cea472] font-accent'
			>
				Thanks for your support
			</span>
			<h1
				class='sm:text-7xl text-5xl font-[GilroyBold] mb-2 text-gray-900 dark:text-white'
			>
				Sponsor
			</h1>
			<p
				class='lg:w-2/3 mx-auto leading-relaxed text-base font-[GilroySemiBold] text-gray-500'
			>
				By sponsoring Wind UI you help the team behind it to continue creating
				wonderful products for the developer community.
			</p>
			<p
				class='lg:w-2/3 mx-auto leading-relaxed text-base font-[GilroySemiBold] text-gray-500'
			>
				For more information, please scroll down.
			</p>
		</div>
		<article class='flex flex-wrap items-center justify-center -m-4'>
			<div
				class='relative overflow-hidden rounded-2xl bg-linear-to-br border border-slate-200 dark:border-0 backdrop-blur-md bg-white/10 dark:from-white/5 dark:to-darker/5 p-8 dark:bg-darker'
			>
				<div class='text-xl font-heading text-white md:text-3xl'>
					<img
						alt='Wind UI'
						src='/svg/DuneUI-logo-black.svg'
						width='150'
						height='70'
						style='max-width: 100%;'
						loading='lazy'
						decoding='async'
					/>
				</div>
				<div
					class='mt-4 text-lg z-10 font-accent text-darker dark:text-gray-300'
				>
					Support the development of Wind UI and get exclusive rewards.
				</div>
				<p class='mt-4 text-lg font-accent text-slate-400 dark:text-slate-500'>
					Design stunning landing pages with the same quality you love on your
					favorite sites. <br class='hidden md:block' />
					Create stunning landing pages with our customizable premium components.
				</p>
				<div class='pt-6 font-accent text-base'>
					<Link />
				</div>
				<Grid />
			</div>
		</article>
	</div>
</section>
