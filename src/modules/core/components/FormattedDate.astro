---
interface Props {
	date: Date | string // Permite recibir Date o string
}

const { date } = Astro.props
const dateObj = typeof date === 'string' ? new Date(date) : date
---

<time datetime={dateObj.toISOString()} class='font-accent'>
	{
		dateObj.toLocaleDateString('en-us', {
			year: 'numeric',
			month: 'short',
			day: 'numeric'
		})
	}
</time>
