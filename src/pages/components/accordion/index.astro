---
import Layout from '@/layouts/Layout.astro';
import ComponentPreview from '@/modules/core/components/ComponentPreview';

// Importamos los HTML usando ?raw
import accordion1Html from '@/data/snippets/application-ui/accordion/01.html?raw';
import accordion2Html from '@/data/snippets/application-ui/accordion/02.html?raw';
---

<Layout title="Accordion Components | DuneUI" description="Beautiful Tailwind CSS Accordion components ready to copy and paste.">
  <div class="relative pt-32 pb-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Premium Header Area -->
    <div class="mb-20 max-w-3xl">
      <a href="/components" class="group inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Components
      </a>

      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 tracking-tight">
        Accordions
      </h1>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">
        Vertically collapsing accordions for showing and hiding content. Perfect for FAQs, feature lists, and information hierarchies.
      </p>

      <div class="mt-6 flex items-center gap-1.5 text-sm font-medium text-slate-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        Last updated on November 4, 2025
      </div>
    </div>

    <!-- Components Display -->
    <div class="space-y-24">
      <section>
        <ComponentPreview 
          title="Minimal Native Accordion" 
          htmlCode={accordion1Html} 
          client:load 
        />
      </section>

      <section>
        <ComponentPreview 
          title="Contained Card with Animated Icons" 
          htmlCode={accordion2Html} 
          client:load 
        />
      </section>
    </div>

  </div>
</Layout>
