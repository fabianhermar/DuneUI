								class='group relative isolate flex-none rounded-md py-1.5 text-[0.8125rem]/6 font-GilroySemibold text-white pl-2.5 pr-[calc(9/16*1rem)]'
								type='submit'><span
									class='absolute inset-0 rounded-md bg-linear-to-b from-white/80 to-white opacity-10 transition-opacity group-hover:opacity-15'></span><span
									class='absolute inset-0 rounded-md opacity-7.5 shadow-[inset_0_1px_1px_white] transition-opacity group-hover:opacity-10'></span>Get
								updates
								<!-- -->
								<span aria-hidden='true'>→</span></button>
							<div class='absolute inset-0 -z-10 rounded-lg transition peer-focus:ring-4 peer-focus:ring-sky-300/15'>
