---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import FormattedDate from '@/core/components/formattedDate.astro'
import Pill from '@/core/components/postPill.astro'
import { Image } from 'astro:assets'
import Calendar from '@/core/design-system/Icons/Calendar.astro'
import Clock from '@/core/design-system/Icons/Clock.astro'

const posts = (await getCollection('blog')).sort(
(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

const featuredPost = posts[0]
const previousPosts = posts.slice(1) // Todos los artículos excepto el destacado
---

<Layout title='Blog - DuneUI'
	description='Read the latest articles and updates on DuneUI, Tailwind CSS components, and templates.'>
	<section class='pt-32 pb-32 mx-auto px-4 md:px-8 lg:px-14 max-w-7xl'>
		<!-- Blog Header -->
		<div class='items-center gap-12 grid mb-20 md:gap-6 md:grid-cols-2 pt-10'>
			<div
				class='relative whitespace-nowrap font-bold h-28 lg:h-[14.5rem] lg:text-[6.5rem] md:h-40 md:text-7xl md:text-left sm:h-[13.5rem] sm:text-8xl text-5xl text-center xs:h-40 xs:text-7xl'>
				<span
					class='flex w-full justify-center absolute font-heading md:justify-start flex-nowrap text-[#d39c64] top-0 z-2'>
					BLOG
				</span><span
					class='flex items-center left-10 absolute font-heading bottom-0 justify-center md:justify-start text-[#e0bd91] top-0 w-full z-1'>
					BLOG
				</span><span
					class='flex w-full justify-center left-20 absolute font-heading md:justify-start bottom-0 text-[#ecd9bc] flex-nowrap'>
					BLOG
				</span>
			</div>
			<div class='flex items-center flex-col max-w-2xl md:items-start md:max-w-none md:text-start mx-auto text-center'
				style='opacity: 1;'>
				<h1 class='font-heading text-2xl lg:text-3xl'>
					DuneUI News and Improvements
				</h1>
				<p class='sm:text-lg font-accent lg:text-xl mt-6 opacity-80'>
					Stay up to date with all of the latest additions and improvements
					we've made to DuneUI.
				</p>
				<form class='flex flex-nowrap gap-4 pt-10' action='https://app.kit.com/forms/8415064/subscriptions' method='post'>
					<div class='max-w-80 flex-1'>
						<div class='group relative'>
							<div class='pointer-events-none absolute left-4 flex h-full items-center'>
								<svg viewBox='0 0 20 20' fill='currentColor'
									class='size-4 text-gray-950/50 group-focus-within:text-gray-950'>
									<path d='M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3Z'>
									</path>
									<path
										d='m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839Z'>
									</path>
								</svg>
							</div><input type='email' required='' autocomplete='email' aria-label='Email address'
								class='block w-80 appearance-none rounded-full bg-white py-2 pr-3 pl-10 text-sm/6 text-gray-950 outline -outline-offset-1 outline-gray-950/8 placeholder:text-sm/6 placeholder:text-gray-950/50 focus:outline-gray-950'
								placeholder='Subscribe via email' name='email_address' />
						</div>
					</div>
					<div>
						<button type='submit'
							class='rounded-full bg-[#d39c64] px-5 py-2 text-sm/6 font-display text-white hover:bg-[#c69a4d]'>Subscribe</button>
					</div>
				</form>
			</div>
		</div>

		<!-- Featured Article Section -->
		{
		featuredPost && (
		<article class='mb-16'>
			<div class='flex items-center gap-3 mb-8'>
				<h2 class='text-2xl md:text-3xl font-heading text-gray-900'>
					Featured Article
				</h2>
			</div>

			<a href={`/blog/${featuredPost.id}/`}
				class='block relative w-full aspect-[2/1] rounded-xl overflow-hidden shadow-2xl hover:shadow-3xl transition-all duration-300 bg-white group cursor-pointer'>
				<Image src={featuredPost.data.heroImage || '/placeholder.svg' } alt={featuredPost.data.title} width={1200}
					height={600}
					class='w-full h-full object-cover transition-transform duration-300 group-hover:scale-105 select-none'
					loading='eager' />
				<div class='absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent' />

				{featuredPost.data.category && (
				<Pill
					style='absolute top-4 md:top-6 left-4 md:left-6 text-white font-semibold px-2 md:px-3 py-1 rounded-full text-xs md:text-sm transition-colors duration-200'>
					{featuredPost.data.category}
				</Pill>
				)}

				<div class='absolute bottom-0 left-0 right-0 p-4 md:p-8 text-white'>
					<h3 class='text-xl md:text-3xl font-bold mb-2 md:mb-3 leading-tight font-display'>
						{featuredPost.data.title}
					</h3>
					<p class='text-sm md:text-lg text-gray-200 mb-3 md:mb-4 leading-relaxed line-clamp-2 font-accent'>
						{featuredPost.data.description}
					</p>
					<div class='flex items-center gap-4 md:gap-6 text-xs md:text-sm text-gray-300'>
						<div class='flex items-center gap-2'>
							<Calendar class='w-3 h-3 md:w-4 md:h-4' />
							<FormattedDate date={featuredPost.data.pubDate} />
						</div>
						{featuredPost.data.readTime && (
						<div class='flex items-center gap-2'>
							<Clock class='w-3 h-3 md:w-4 md:h-4' />
							<span class='font-accent'>
								{featuredPost.data.readTime} min
							</span>
						</div>
						)}
					</div>
				</div>
			</a>
		</article>
		)
		}

		<!-- Previous Articles Section -->
		{
		previousPosts.length > 0 && (
		<section>
			<div class='flex items-center gap-3 mb-8'>
				<h2 class='text-2xl md:text-3xl font-heading text-gray-900'>
					Previous Articles
				</h2>
			</div>

			<div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8'>
				{previousPosts.map((post) => (
				<article
					class='group bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer'>
					<a href={`/blog/${post.id}/`} class='block'>
						<div class='relative w-full aspect-[4/3] overflow-hidden'>
							<Image src={post.data.heroImage || '/placeholder.svg' } alt={post.data.title} width={400} height={300}
								class='w-full h-full object-cover transition-transform duration-300 group-hover:scale-110 select-none'
								loading='lazy' />
							<div
								class='absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300' />

							{post.data.category && (
							<Pill
								style='absolute top-4 md:top-6 left-4 md:left-6 text-white font-semibold px-2 md:px-3 py-1 rounded-full text-xs md:text-sm transition-colors duration-200'>
								{featuredPost.data.category}
							</Pill>
							)}
						</div>

						<div class='p-4 md:p-6'>
							<h3
								class='text-lg md:text-xl font-display text-gray-900 mb-2 md:mb-3 leading-tight transition-colors duration-200 line-clamp-2'>
								{post.data.title}
							</h3>
							<p class='text-gray-600 mb-3 md:mb-4 leading-relaxed text-sm font-accent line-clamp-3'>
								{post.data.description}
							</p>
							<div class='flex items-center justify-between text-xs text-gray-500'>
								<div class='flex items-center gap-1'>
									<Calendar class='w-3 h-3' />
									<FormattedDate date={post.data.pubDate} />
								</div>
								{post.data.readTime && (
								<div class='flex items-center gap-1'>
									<Clock class='w-3 h-3' />
									<span class='font-accent'>
										{post.data.readTime} min
									</span>
								</div>
								)}
							</div>
						</div>
					</a>
				</article>
				))}
			</div>
		</section>
		)
		}
	</section>
</Layout>
