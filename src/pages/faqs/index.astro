---
import Layout from '@/layouts/Layout.astro'

const groups = [
  {
    id: 'general',
    label: 'General',
    icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>`,
    items: [
      {
        q: 'What is DuneUI?',
        a: 'DuneUI is a free, open-source library of UI components and page sections built with TailwindCSS. It\'s designed to help you ship beautiful interfaces faster — no account required, no restrictions.',
      },
      {
        q: 'Is DuneUI completely free?',
        a: 'Yes. Every component is free for personal and commercial projects. No payment, no attribution needed.',
      },
      {
        q: 'Do I need to create an account?',
        a: 'No. All components are accessible directly from the website. Just browse, find what you need, and copy the code.',
      },
      {
        q: 'Who is DuneUI made for?',
        a: 'Developers who use TailwindCSS and want production-ready UI blocks without starting from scratch. Whether you\'re building a SaaS, a marketing site, or a personal project — DuneUI has something for you.',
      },
    ],
  },
  {
    id: 'components',
    label: 'Components',
    icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
    items: [
      {
        q: 'Which frameworks are supported?',
        a: 'Components are written in plain HTML + TailwindCSS, making them compatible with any framework: React, Vue, Svelte, Astro, Next.js, and more. Copy the markup and adapt it to your framework\'s syntax.',
      },
      {
        q: 'Can I modify the components?',
        a: 'Absolutely. Components are a starting point, not a constraint. Modify colors, spacing, layout, and typography however you want. They\'re yours once you copy them.',
      },
      {
        q: 'Are the components accessible?',
        a: 'We follow accessibility best practices including semantic HTML, ARIA labels, and keyboard navigation on all interactive components. We\'re continuously improving this with each release.',
      },
      {
        q: 'Which TailwindCSS version is used?',
        a: 'As of v2.0, DuneUI is built with TailwindCSS v4. Components from earlier versions may use v3 syntax and are being updated progressively.',
      },
      {
        q: 'Are there full-page templates?',
        a: 'Yes. The Templates section includes complete page layouts ready to be used as project starters. More are added with each major release.',
      },
    ],
  },
  {
    id: 'license',
    label: 'License & Usage',
    icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    items: [
      {
        q: 'Can I use DuneUI in commercial projects?',
        a: 'Yes. Use any component in commercial projects — SaaS apps, client websites, e-commerce stores, and more. No restrictions.',
      },
      {
        q: 'Can I redistribute components as a UI library?',
        a: 'No. You cannot package DuneUI components into a UI library or component package and distribute it publicly, whether for free or for sale. You are free to use them inside your own product.',
      },
      {
        q: 'Do I need to credit DuneUI?',
        a: 'Attribution is not required. A mention is always appreciated and helps the project grow, but it\'s entirely optional.',
      },
      {
        q: 'Can I use DuneUI for client projects?',
        a: 'Yes. Build websites and applications for clients using DuneUI components. The resulting product belongs to your client.',
      },
    ],
  },
  {
    id: 'technical',
    label: 'Technical',
    icon: `<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    items: [
      {
        q: 'Do I need to install a package?',
        a: 'No. DuneUI is copy-paste based. Just make sure TailwindCSS is set up in your project and paste the component code directly.',
      },
      {
        q: 'How do I set up TailwindCSS?',
        a: 'Follow the official TailwindCSS installation guide at tailwindcss.com/docs/installation. DuneUI components work out of the box once Tailwind is configured.',
      },
      {
        q: 'What fonts do DuneUI components use?',
        a: 'DuneUI uses "Albert Sans" and "Urbanist" as primary fonts, loaded via @fontsource. You can swap them for your own font system by updating font-family in your Tailwind config.',
      },
    ],
  },
]
---

<Layout
  title='FAQs · DuneUI'
  description='Frequently asked questions about DuneUI — components, licensing, usage, and more.'
>
  <!-- ── Header ────────────────────────────────────── -->
  <div class='mx-auto w-full max-w-4xl px-4 sm:px-6 pt-32 pb-16'>
    <div class='max-w-2xl'>
      <span class='inline-block text-xs font-semibold font-accent uppercase tracking-[0.2em] text-[#93603e] mb-4'>
        Got questions?
      </span>
      <h1 class='text-5xl lg:text-6xl font-bold font-heading text-neutral-900 leading-[1.05] tracking-tight'>
        Frequently asked<br/>questions
      </h1>
      <p class='mt-5 text-base font-accent text-neutral-500 leading-relaxed'>
        Everything you need to know about DuneUI. Can't find the answer you're looking for?{' '}
        <a href='https://x.com/FabianHermar' target='_blank' rel='noreferrer' class='text-[#93603e] font-semibold underline underline-offset-2 hover:text-[#7a4f33] transition-colors'>
          Reach out on Twitter.
        </a>
      </p>
    </div>
  </div>

  <!-- ── Content ───────────────────────────────────── -->
  <div class='mx-auto w-full max-w-4xl px-4 sm:px-6 pb-28'>
    <div class='flex flex-col gap-16' id='faq-root'>
      {groups.map((group) => (
        <section>
          <!-- Group header -->
          <div class='flex items-center gap-3 mb-10'>
            <div class='flex h-8 w-8 items-center justify-center rounded-lg bg-[#f6edde] text-[#93603e]'>
              <Fragment set:html={group.icon} />
            </div>
            <h2 class='text-base font-bold font-heading text-neutral-900'>
              {group.label}
            </h2>
            <div class='flex-1 h-px bg-neutral-100'></div>
          </div>

          <!-- Accordion items -->
          <div class='space-y-px rounded-xl overflow-hidden border border-neutral-100 shadow-sm'>
            {group.items.map((item, i) => (
              <div class='faq-item bg-white' data-q={item.q.toLowerCase()}>
                <button
                  class='faq-trigger flex w-full items-start justify-between gap-6 px-6 py-5 text-left'
                  aria-expanded='false'
                >
                  <span class='text-sm font-semibold font-accent text-neutral-800 leading-snug pt-px'>
                    {item.q}
                  </span>
                  <span class='faq-chevron mt-0.5 shrink-0 text-neutral-400 transition-transform duration-300'>
                    <svg class='size-4' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2'>
                      <path stroke-linecap='round' stroke-linejoin='round' d='M19 9l-7 7-7-7' />
                    </svg>
                  </span>
                </button>
                <div class='faq-body max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out'>
                  <p class='px-6 pb-5 text-sm font-accent text-neutral-500 leading-relaxed'>
                    {item.a}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Still have questions -->
    <div class='mt-28 rounded-2xl bg-neutral-950 px-8 py-10 text-center'>
      <p class='text-xs font-semibold font-accent uppercase tracking-[0.2em] text-neutral-500 mb-3'>Still stuck?</p>
      <h3 class='text-2xl font-bold font-heading text-white mb-2'>We're happy to help</h3>
      <p class='text-sm font-accent text-neutral-400 mb-7 max-w-sm mx-auto leading-relaxed'>
        Can't find the answer you're looking for? Reach out and we'll get back to you.
      </p>
      <a
        href='https://x.com/FabianHermar'
        target='_blank'
        rel='noreferrer noopener'
        class='inline-flex items-center gap-2.5 rounded-full bg-white px-6 py-3 text-sm font-semibold font-accent text-neutral-900 hover:bg-neutral-100 transition-colors duration-200'
      >
        <svg class='size-4' fill='currentColor' viewBox='0 0 24 24'>
          <path d='M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84' />
        </svg>
        Ask on Twitter
      </a>
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item')!
      const body = item.querySelector<HTMLElement>('.faq-body')!
      const chevron = item.querySelector<HTMLElement>('.faq-chevron')!
      const isOpen = btn.getAttribute('aria-expanded') === 'true'

      // Close all in the same group
      const group = item.closest('section')!
      group.querySelectorAll('.faq-item').forEach(other => {
        if (other !== item) {
          other.querySelector<HTMLButtonElement>('.faq-trigger')!.setAttribute('aria-expanded', 'false')
          const ob = other.querySelector<HTMLElement>('.faq-body')!
          ob.style.maxHeight = '0'
          other.querySelector<HTMLElement>('.faq-chevron')!.style.transform = ''
        }
      })

      if (isOpen) {
        btn.setAttribute('aria-expanded', 'false')
        body.style.maxHeight = '0'
        chevron.style.transform = ''
      } else {
        btn.setAttribute('aria-expanded', 'true')
        body.style.maxHeight = body.scrollHeight + 'px'
        chevron.style.transform = 'rotate(180deg)'
      }
    })
  })
</script>
