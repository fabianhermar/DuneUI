---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'

const entries = (await getCollection('changelog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' })
}

const tagStyles: Record<string, string> = {
  New:      'bg-emerald-50 text-emerald-700 border-emerald-200',
  Improved: 'bg-sky-50    text-sky-700    border-sky-200',
  Fixed:    'bg-amber-50  text-amber-700  border-amber-200',
  Breaking: 'bg-red-50    text-red-700    border-red-200',
}
---

<Layout
  title='Changelog · DuneUI'
  description='Every update, new component, bug fix, and improvement shipped to DuneUI.'
>
  <!-- ── Page header ───────────────────────────────── -->
  <div class='mx-auto w-full max-w-4xl px-4 sm:px-6 pt-32 pb-6'>
    <span class='inline-block text-xs font-semibold font-accent uppercase tracking-[0.2em] text-[#93603e] mb-4'>
      Release history
    </span>
    <h1 class='text-5xl lg:text-6xl font-bold font-heading text-neutral-900 leading-[1.05] tracking-tight'>
      Changelog
    </h1>
    <p class='mt-4 max-w-lg text-base font-accent text-neutral-500 leading-relaxed'>
      Every update, new component, and improvement we've shipped — in one place.
    </p>
  </div>

  <!-- ── Divider ───────────────────────────────────── -->
  <div class='mx-auto w-full max-w-4xl px-4 sm:px-6 mb-14'>
    <div class='flex items-center gap-4'>
      <div class='h-px flex-1 bg-neutral-100'></div>
      <span class='text-xs font-semibold font-accent uppercase tracking-widest text-neutral-400'>
        {entries.length} release{entries.length !== 1 ? 's' : ''}
      </span>
      <div class='h-px flex-1 bg-neutral-100'></div>
    </div>
  </div>

  <!-- ── Timeline entries ──────────────────────────── -->
  <div class='mx-auto w-full max-w-4xl px-4 sm:px-6 pb-28'>
    <div class='relative'>

      <!-- Vertical line -->
      <div class='absolute left-[7.5rem] top-0 bottom-0 w-px bg-neutral-100 max-sm:hidden'></div>

      <div class='space-y-0'>
        {entries.map((entry, i) => (
          <div class='group relative flex gap-0 sm:gap-10'>

            <!-- Date column (desktop) -->
            <div class='hidden sm:flex w-28 shrink-0 flex-col items-end pt-9'>
              <time
                class='text-xs font-accent text-neutral-400 leading-none text-right'
                datetime={entry.data.pubDate.toISOString()}
              >
                {formatDate(entry.data.pubDate).replace(/(\d+)\s(\w+)\s(\d+)/, '$2 $3')}
              </time>
            </div>

            <!-- Dot on timeline -->
            <div class='hidden sm:flex flex-col items-center'>
              <div class='relative mt-[2.35rem]'>
                <div class='h-3 w-3 rounded-full border-2 border-[#93603e] bg-white ring-4 ring-white transition-all duration-300 group-hover:bg-[#93603e]'></div>
              </div>
            </div>

            <!-- Content -->
            <a
              href={`/changelog/${entry.id}/`}
              class='block flex-1 min-w-0 py-8 border-b border-neutral-100 last:border-0'
            >

              <!-- Version + tags (mobile date here too) -->
              <div class='flex flex-wrap items-center gap-2 mb-3'>
                <span class='rounded-md bg-[#f6edde] border border-[#d39c64]/30 px-2.5 py-0.5 text-xs font-bold font-accent text-[#93603e] tracking-wide'>
                  {entry.data.version}
                </span>
                {entry.data.tags?.map(tag => (
                  <span class={`rounded-md border px-2 py-0.5 text-[10px] font-bold font-accent uppercase tracking-wide ${tagStyles[tag] ?? 'bg-gray-50 text-gray-600 border-gray-200'}`}>
                    {tag}
                  </span>
                ))}
                <time
                  class='sm:hidden ml-auto text-xs font-accent text-neutral-400'
                  datetime={entry.data.pubDate.toISOString()}
                >
                  {formatDate(entry.data.pubDate)}
                </time>
              </div>

              <!-- Title -->
              <h2 class='text-xl font-bold font-heading text-neutral-900 leading-snug mb-2 group-hover:text-[#93603e] transition-colors'>
                {entry.data.title}
              </h2>

              <!-- Description -->
              <p class='text-sm font-accent text-neutral-500 leading-relaxed mb-5'>
                {entry.data.description}
              </p>

              <!-- Image -->
              {entry.data.image && (
                <div class='mb-5 w-full aspect-video rounded-xl overflow-hidden border border-neutral-100 shadow-sm'>
                  <img
                    src={entry.data.image}
                    alt={entry.data.title}
                    width={800}
                    height={450}
                    class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 select-none'
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </div>
              )}

              <!-- Read more link -->
              <span
                class='inline-flex items-center gap-1.5 text-xs font-semibold font-accent text-[#93603e] group-hover:text-[#7a4f33] transition-colors duration-200'
              >
                Read release notes
                <svg class='size-3.5 transition-transform duration-200 group-hover:translate-x-0.5' fill='none' viewBox='0 0 24 24' stroke='currentColor' stroke-width='2.5'>
                  <path stroke-linecap='round' stroke-linejoin='round' d='M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3' />
                </svg>
              </span>

            </a>
          </div>
        ))}
      </div>

    </div>
  </div>
</Layout>
